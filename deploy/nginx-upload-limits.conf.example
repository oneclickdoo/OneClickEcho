# Include in server { ... } for viber.oneclick.rs (or paste directives into existing server block).
# Then: sudo nginx -t && sudo systemctl reload nginx
#
# 413 Request Entity Too Large = body over client_max_body_size (default often 1m).

client_max_body_size 100M;

# Large CSV / video upload through reverse proxy (optional but helps slow links)
proxy_connect_timeout 600s;
proxy_send_timeout 600s;
proxy_read_timeout 600s;
